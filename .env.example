# =====================================================================
# wpp-multi — Variáveis de ambiente
# Copie para .env (e para apps/api/.env) e preencha com valores reais.
# =====================================================================

# --- Banco (Supabase Postgres) ---
# String de conexão do Postgres do Supabase (porta 5432 com pgBouncer ou 6543 direta).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wpp_multi?schema=public"
# URL "direct" (sem pooler) usada por prisma migrate.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/wpp_multi?schema=public"

# --- Supabase ---
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# --- API (Fastify) ---
API_HOST="0.0.0.0"
API_PORT="3333"
API_CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL="info"

# --- WhatsApp (Baileys) ---
# Diretório (no servidor) onde as credenciais Baileys de cada departamento são salvas.
BAILEYS_AUTH_DIR="./baileys-auth"
# Diretório onde mídias recebidas/enviadas serão armazenadas (on-premise).
MEDIA_STORE_DIR="./media-store"

# --- Web (Vite) ---
VITE_API_URL="http://localhost:3333"
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY=""
