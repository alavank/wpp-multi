{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "@wpp/shared": ["../../packages/shared/src/index.ts"],
      "@wpp/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
