{
  "name": "wpp-multi",
  "version": "0.0.1",
  "private": true,
  "description": "Sistema on-premise de multiatendimento WhatsApp (multidepartamento, multiusuário).",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "dev:web": "pnpm --filter @wpp/web dev",
    "dev:api": "pnpm --filter @wpp/api dev",
    "build": "pnpm -r --filter \"./packages/*\" run build && pnpm -r --filter \"./apps/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter @wpp/api exec prisma generate",
    "db:migrate": "pnpm --filter @wpp/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @wpp/api exec prisma studio",
    "db:format": "pnpm --filter @wpp/api exec prisma format",
    "db:validate": "pnpm --filter @wpp/api exec prisma validate"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
